{
  "name": "pixengine",
  "module": "src/index.ts",
  "packageManager": "bun@1.3.8",
  "scripts": {
    "format": "biome check --write . .docs",
    "lint": "biome lint . .docs",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "check": "bun run typecheck && biome check . .docs && bun test",
    "commitlint": "commitlint --config commitlint.config.cjs",
    "render:smoke": "bun run scripts/render-smoke.ts",
    "render:project": "bun run scripts/render-project.ts",
    "render:all": "bun run scripts/render-all.ts",
    "refresh:goldens": "bun run scripts/refresh-goldens.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "pngjs": "7.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@types/bun": "1.3.12",
    "@types/pngjs": "6.0.5",
    "husky": "9.1.7",
    "typescript": "6.0.3"
  },
  "private": true,
  "type": "module"
}
